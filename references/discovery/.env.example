# =============================================================================
# .env.example — Environment variables for Discovery (24/7 Infrastructure)
# Copy to .env and fill in real values before first boot.
# =============================================================================

# -----------------------------------------------------------------------------
# System
# -----------------------------------------------------------------------------
PUID=1000
PGID=1000
TZ=America/Sao_Paulo

# -----------------------------------------------------------------------------
# Network
# -----------------------------------------------------------------------------
HOMELAB_DOMAIN=homelab.pastelariadev.com
HOMELAB_SUBNET=172.20.0.0/24
HOMELAB_GATEWAY=172.20.0.1
DISCOVERY_LAN_IP=192.168.10.210
DISCOVERY_TAILSCALE_IP=

# -----------------------------------------------------------------------------
# Storage Paths
# -----------------------------------------------------------------------------
# APPS_PATH: app configs and databases (inside homelab/config folder)
# MEDIA_PATH: HDD mount for media files (movies, tv, music, audiobooks, downloads)
APPS_PATH=/home/erik/homelab/config
MEDIA_PATH=/home/erik/vault/media

# -----------------------------------------------------------------------------
# Tailscale mesh hostnames (cross-machine communication)
# -----------------------------------------------------------------------------
# Use LAN IPs initially, switch to Tailscale MagicDNS names after mesh is up
ORION_HOST=192.168.10.220
KEPLER_HOST=cygnus
DISCOVERY_HOST=192.168.10.210

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------
POSTGRES_USER=homelab
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB_SONARR=sonarr
POSTGRES_DB_RADARR=radarr
POSTGRES_DB_LIDARR=lidarr
POSTGRES_DB_PROWLARR=prowlarr
POSTGRES_DB_AUTHENTIK=authentik
POSTGRES_DB_GITEA=gitea
POSTGRES_DB_LANGFUSE=langfuse
POSTGRES_DB_HEALTHCHECKS=healthchecks

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=changeme

# -----------------------------------------------------------------------------
# Vault
# -----------------------------------------------------------------------------
VAULT_DEV_ROOT_TOKEN=devtoken

# -----------------------------------------------------------------------------
# Vaultwarden
# -----------------------------------------------------------------------------
VAULTWARDEN_ADMIN_TOKEN=changeme


# -----------------------------------------------------------------------------
# Monitoring — Grafana
# -----------------------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme

# -----------------------------------------------------------------------------
# Monitoring — Healthchecks
# -----------------------------------------------------------------------------
HEALTHCHECKS_SECRET_KEY=changeme-long-random-string
HEALTHCHECKS_SITE_ROOT=https://healthchecks.homelab.pastelariadev.com
HEALTHCHECKS_ALLOWED_HOSTS=healthchecks.homelab.pastelariadev.com,healthchecks
HEALTHCHECKS_SUPERUSER_EMAIL=erikbogado@gmail.com
HEALTHCHECKS_SUPERUSER_PASSWORD=changeme

# -----------------------------------------------------------------------------
# Monitoring — ntfy
# -----------------------------------------------------------------------------
NTFY_BASE_URL=https://ntfy.homelab.pastelariadev.com

# -----------------------------------------------------------------------------
# Cloudflare
# -----------------------------------------------------------------------------
# Tunnel token: Cloudflare Zero Trust → Networks → Tunnels → Create
CLOUDFLARE_TUNNEL_TOKEN=changeme
# API token for DNS-01 TLS challenge: Cloudflare → My Profile → API Tokens
# Create token with Zone:DNS:Edit permission for pastelariadev.com
CLOUDFLARE_API_TOKEN=changeme
ACME_EMAIL=erikbogado@gmail.com

# -----------------------------------------------------------------------------
# Tunneling — Tailscale
# -----------------------------------------------------------------------------
TAILSCALE_AUTHKEY=tskey-auth-changeme
TAILSCALE_HOSTNAME=discovery
TAILSCALE_ADVERTISE_ROUTES=192.168.10.0/24

# -----------------------------------------------------------------------------
# Backups — Restic (3 daily / 6 weekly / 12 monthly)
# -----------------------------------------------------------------------------
RESTIC_REPOSITORY=sftp:erik@192.168.10.220:/home/erik/backups/discovery
RESTIC_PASSWORD=changeme-long-random-string

# -----------------------------------------------------------------------------
# Notifications — Telegram (used by Grafana, Healthchecks)
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=changeme
TELEGRAM_CHAT_ID=changeme

# -----------------------------------------------------------------------------
# VPN (NordVPN via Gluetun)
# -----------------------------------------------------------------------------
# Use NordVPN SERVICE credentials (not account email/password)
# Get them at: nordvpn.com -> My Account -> Manual Setup -> Service credentials
NORDVPN_USER=
NORDVPN_PASSWORD=
VPN_COUNTRIES=Brazil

# -----------------------------------------------------------------------------
# Media (*arr apps) — 32-char lowercase hex API keys
# -----------------------------------------------------------------------------
# Generate with: openssl rand -hex 16
# These keys are pre-seeded into each app's config.xml by setup.sh.
# After first boot, verify keys match: Settings > General > API Key in each app.
# WARNING: Do NOT use base64 keys (44 chars) — *arr apps require exactly 32 hex chars.
SONARR_API_KEY=
RADARR_API_KEY=
LIDARR_API_KEY=

# -----------------------------------------------------------------------------
# Plex
# -----------------------------------------------------------------------------
# Get a fresh claim token from plex.tv/claim (valid 4 minutes)
PLEX_CLAIM=

# -----------------------------------------------------------------------------
# Jellystat
# -----------------------------------------------------------------------------
JELLYSTAT_JWT_SECRET=changeme

# -----------------------------------------------------------------------------
# LiteLLM (AI gateway — runs on Discovery for 24/7 availability)
# -----------------------------------------------------------------------------
LITELLM_MASTER_KEY=changeme
LITELLM_SALT_KEY=changeme
UI_USERNAME=admin
UI_PASSWORD=changeme
LANGFUSE_PUBLIC_KEY=changeme
LANGFUSE_SECRET_KEY=changeme
LANGFUSE_SALT=changeme
LANGFUSE_INIT_USER_EMAIL=erikbogado@gmail.com
LANGFUSE_INIT_USER_PASSWORD=changeme
LANGFUSE_INIT_ORG_ID=1
LANGFUSE_INIT_ORG_NAME=Homelab
LANGFUSE_INIT_PROJECT_NAME=AI Stack

# -----------------------------------------------------------------------------
# ClickHouse (Langfuse OLAP backend)
# -----------------------------------------------------------------------------
CLICKHOUSE_USER=clickhouse
CLICKHOUSE_PASSWORD=changeme
CLICKHOUSE_DB=default

# -----------------------------------------------------------------------------
# MinIO (Langfuse S3 — remote on Cygnus, port 9191)
# -----------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme
MINIO_STORAGE_BUCKET=langfuse

# -----------------------------------------------------------------------------
# Renovate — dependency update bot
# -----------------------------------------------------------------------------
RENOVATE_TOKEN=changeme
RENOVATE_REPOSITORIES=your-org/your-repo
RENOVATE_PLATFORM=github

# -----------------------------------------------------------------------------
# Scrutiny — SMART disk health monitoring
# -----------------------------------------------------------------------------
SCRUTINY_INFLUXDB_TOKEN=changeme-long-random-string
SCRUTINY_INFLUXDB_PASSWORD=changeme
