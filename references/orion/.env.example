# =============================================================================
# .env.example — Orion (Bazzite, AMD GPU — AI Workstation)
# Copy to .env and fill in values before starting
# =============================================================================

# --- System ---
PUID=1000
PGID=1000
TZ=Europe/Amsterdam

# --- Tailscale mesh hostnames ---
ORION_HOST=orion
KEPLER_HOST=kepler
DISCOVERY_HOST=discovery

# --- Tailscale ---
TAILSCALE_AUTHKEY=tskey-auth-XXXXX
TAILSCALE_HOSTNAME=orion

# --- AI Models ---
MODELS_PATH=/opt/models
LLAMA_CHAT_MODEL=qwen3.5-27b-q3_k_s.gguf
EMBED_MODEL=Qwen3-Embedding-0.6B-GGUF/Qwen3-Embedding-0.6B-Q8_0.gguf
# NOTE: Model args (context size, batch size, flash attention, etc.) are
# defined in the compose command section of ai-models.yml, not as env vars.

# --- Hermes Agent ---
LITELLM_API_KEY=
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=
EXA_API_KEY=

# -----------------------------------------------------------------------------
# Scrutiny — SMART disk health collector → Discovery hub
# -----------------------------------------------------------------------------
SCRUTINY_API_ENDPOINT=http://discovery:8080

# -----------------------------------------------------------------------------
# Hawser — Dockhand remote agent token
# -----------------------------------------------------------------------------
HAWSER_TOKEN=changeme-generate-with-openssl-rand-base64-32
